{
  "name": "governance-console",
  "version": "0.1.0",
  "description": "Local, offline-capable governance console — interactive risk assessment over the toolkit's scoring rubric.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "verify:ci": "npm run typecheck && npm run lint && npm test -- --run && npm run build"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "i18next": "^23.16.8",
    "react-i18next": "^14.1.3"
  },
  "devDependencies": {
    "vite": "^8.1.4",
    "@vitejs/plugin-react": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "eslint": "^9.39.1",
    "@eslint/js": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.14.0",
    "vitest": "^3.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
